        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <div class="grid lg:grid-cols-2 rounded-3xl overflow-hidden bg-[#EFE4D4]">

                <div class="min-h-[450px] bg-[#D8C2A8]"></div>

                <div class="p-12 lg:p-16 flex flex-col justify-center">

