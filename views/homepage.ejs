<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FLOURish Bakery</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>

<body class="bg-[#F8F4EE] text-[#4A3428]">
    <!-- NAVBAR -->

    <nav class="fixed top-0 left-0 w-full z-50 bg-[#F8F4EE]/80 backdrop-blur-md border-b border-[#E8DCCB]">

        <div class="w-[90%] mx-auto">

            <div class="h-20 flex items-center justify-between">

                <!-- Logo -->

                <div class="w-[48%] flex items-center gap-3">

                    <i class="fa-solid fa-wheat-awn text-3xl text-[#C9A36B]"></i>

                    <div>

                        <h1 class="font-serif text-4xl">
                            FLOUR<span class="italic text-[#C9A36B]">ish</span>
                        </h1>

                    </div>

                </div>

                <!-- Desktop Links -->

                <ul class="w-[32%] md:flex items-center justify-around text-sm uppercase tracking-wide">

                    <li>
                        <a href="/" class="hover:text-[#C9A36B] transition">
                            Home
                        </a>
                    </li>

                    <li>
                        <a href="/menu" class="hover:text-[#C9A36B] transition">
                            Our Menu
                        </a>
                    </li>

                    <li>
                        <a href="/about" class="hover:text-[#C9A36B] transition">
                            About
                        </a>
                    </li>

                    <!-- <li>
                        <a href="/cakes" class="hover:text-[#C9A36B] transition">
                            Custom Cakes
                        </a>
                    </li> -->

                    <li>
                        <a href="/contact" class="hover:text-[#C9A36B] transition">
                            Contact Us
                        </a>
                    </li>

                </ul>

                <!-- Right Side -->

                <div class="flex items-center justify-around gap-5">

                    <!-- <a href="/search">
                        <i class="fa-solid fa-magnifying-glass text-lg hover:text-[#C9A36B] transition"></i>
                    </a> -->

                    <a href="/login"
                        class="bg-[#4A3428] text-white px-5 py-2 rounded-full hover:bg-[#7A5C45] transition">

                        Sign In

                    </a>

                </div>

            </div>

        </div>

    </nav>


    <!-- HERO -->

    <section class="pt-28">

        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <div
                class="relative min-h-[750px] rounded-3xl overflow-hidden flex items-center"
                style="
                    background-image:url('/images/homepage.png');
                    background-size:cover;
                    background-position:center;
                "
            >

                <!-- Overlay -->

                <div class="absolute inset-0 bg-black/40"></div>

                <!-- Content -->

                <div class="relative z-10 px-8 md:px-16 lg:px-24 max-w-4xl">

                    <p class="uppercase tracking-[8px] text-[#D9B97A] text-sm font-semibold">

                        Freshly Baked Daily

                    </p>

                    <h1 class="mt-6 text-white font-serif text-5xl md:text-7xl font-bold leading-tight">

                        Where Every Bite
                        <br>
                        Feels Like Home

                    </h1>

                    <p class="mt-8 text-white/90 text-lg md:text-xl max-w-2xl">

                        Experience handcrafted breads, flaky pastries,
                        custom cakes and sweet treats baked with
                        love every single day.

                    </p>

                    <a
                        href="/menu"
                        class="inline-block mt-10 bg-[#C9A36B] text-[#2F241D] px-8 py-4 rounded-md font-bold uppercase tracking-wide hover:bg-[#B89056] transition">

                        Explore Our Menu

                    </a>

                </div>

            </div>

        </div>

    </section>


    <!-- DAILY DELIGHTS -->

    <section class="py-28">

        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <div class="text-center">

                <h2 class="font-serif text-5xl md:text-6xl">

                    Our Daily Delights

                </h2>

                <p class="mt-5 text-[#6B5B50] max-w-2xl mx-auto">

                    Freshly prepared every day using quality ingredients,
                    traditional techniques and a passion for baking.

                </p>

            </div>

            <div class="h-[50vh] grid md:grid-cols-2 lg:grid-cols-4 gap-8 mt-16">

                <div class="bg-white rounded-2xl shadow-sm hover:shadow-lg transition relative overflow-hidden">
                    <img src="/images/artisanBread.png" alt="" class="absolute z-1 h-[60%] left-0 top-0">
                    <!-- <div class="w-20 h-20 mx-auto rounded-full bg-[#F5EBDD] flex items-center justify-center">

                        <i class="fa-solid fa-bread-slice text-3xl text-[#C9A36B]"></i>

                    </div> -->
                    <div class="h-[50%] w-[100%] p-2 bg-[#F8F4EE] top-[50%] relative z-5">

                        <h3 class="mt-2 text-center font-serif text-xl font-bold">

                            Artisan Breads

                        </h3>

                        <p class="mt-2 text-center text-[#6B5B50]">

                            Sourdough, baguettes and fresh loaves.

                        </p>

                        <button
                            class="block w-[90%] mt-4 mx-auto py-3 bg-[#C9A36B] text-sm rounded-md font-semibold hover:bg-[#B89056] transition">

                            VIEW ALL

                        </button>

                    </div>

                </div>



                <div class="bg-white rounded-2xl shadow-sm hover:shadow-lg transition relative overflow-hidden">
                    <img src="/images/pastries.png" alt="" class="absolute z-1 h-[50%] left-0 top-0">
                    <!-- <div class="w-20 h-20 mx-auto rounded-full bg-[#F5EBDD] flex items-center justify-center">

                        <i class="fa-solid fa-bread-slice text-3xl text-[#C9A36B]"></i>

                    </div> -->
                    <div class="h-[50%] w-[100%] p-2 bg-[#F8F4EE] top-[50%] relative z-5">

                        <h3 class="mt-2 text-center font-serif text-xl font-bold">

                            Pastries

                        </h3>

                        <p class="mt-2 text-center text-[#6B5B50]">

                            Croissants, Pain Aux Chocolate and various danish pastries

                        </p>

                        <button class="block w-[90%] mt-4 mx-auto py-3 bg-[#C9A36B] text-sm rounded-md font-semibold hover:bg-[#B89056] transition">

                            VIEW ALL

                        </button>

                    </div>

                </div>



                <div class="bg-white rounded-2xl shadow-sm hover:shadow-lg transition relative overflow-hidden">
                    <img src="/images/Cakes.png" alt="" class="absolute z-1 h-[55%] left-0 top-0">
                    <!-- <div class="w-20 h-20 mx-auto rounded-full bg-[#F5EBDD] flex items-center justify-center">

                        <i class="fa-solid fa-bread-slice text-3xl text-[#C9A36B]"></i>

                    </div> -->
                    <div class="h-[50%] w-[100%] p-2 bg-[#F8F4EE] top-[50%] relative z-5">

                        <h3 class="mt-2 text-center font-serif text-xl font-bold">

                            Cakes

                        </h3>

                        <p class="mt-2 text-center text-[#6B5B50]">

                            Birthday, wedding and custom cakes for various events

                        </p>

                        <button class="block w-[90%] mt-4 mx-auto py-3 bg-[#C9A36B] text-sm rounded-md font-semibold hover:bg-[#B89056] transition">

                            VIEW ALL

                        </button>

                    </div>

                </div>



                <div class="bg-white rounded-2xl shadow-sm hover:shadow-lg transition relative overflow-hidden">
                    <img src="/images/cookies.png" alt="" class="absolute z-1 h-[60%] left-0 top-0">
                    <!-- <div class="w-20 h-20 mx-auto rounded-full bg-[#F5EBDD] flex items-center justify-center">

                        <i class="fa-solid fa-bread-slice text-3xl text-[#C9A36B]"></i>

                    </div> -->
                    <div class="h-[50%] w-[100%] p-2 bg-[#F8F4EE] top-[50%] relative z-5">

                        <h3 class="mt-2 text-center font-serif text-xl font-bold">

                            Cookies

                        </h3>

                        <p class="mt-2 text-center text-[#6B5B50]">

                             Freshly baked choco chip, raisin and various cookies

                        </p>

                        <button class="block w-[90%] mt-4 mx-auto py-3 bg-[#C9A36B] text-sm rounded-md font-semibold hover:bg-[#B89056] transition">

                            VIEW ALL

                        </button>

                    </div>

                </div>

            </div>

        </div>

    </section>
        <!-- FEATURED PRODUCTS -->

    <section class="pb-28">

        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <div class="flex items-center justify-between mb-12">

                <h2 class="font-serif text-5xl">
                    Customer Favorites
                </h2>

                <a href="/menu"
                   class="text-[#C9A36B] font-semibold hover:underline">

                    View Full Menu

                </a>

            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

                <% const products = [
                    {
                        name: "Croissant",
                        price: "₹360",
                        image: '/images/croissant.png'
                    },
                    {
                        name: "Chocolate Cake",
                        price: "₹800",
                        image: '/images/chocolateCake.png'
                    },
                    {
                        name: "Sourdough Loaf",
                        price: "₹300",
                        image: '/images/sourdough.png'
                    }
                ] %>

                <% products.forEach(product => { %>

                    <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition">

                        <div class="h-72 bg-[#E8DCCB]">
                            <img src="<%=product.image%>" alt="" class="h-[100%]">
                        </div>

                        <div class="p-6">

                            <h3 class="font-serif text-2xl">
                                <%= product.name %>
                            </h3>

                            <p class="mt-2 text-[#6B5B50]">
                                Freshly baked with premium ingredients.
                            </p>

                            <div class="mt-5 flex items-center justify-between">

                                <span class="font-bold text-xl">
                                    <%= product.price %>
                                </span>

                                <button class="bg-[#C9A36B] px-5 py-2 rounded-md hover:bg-[#B89056] transition">

                                    Add To Cart

                                </button>

                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

        </div>

    </section>



