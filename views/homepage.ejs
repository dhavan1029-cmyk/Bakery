                    <button class="mt-8 w-fit bg-[#4A3428] text-white px-8 py-4 rounded-md hover:bg-[#6A4B39] transition">

                        Order Now

                    </button>

                </div>

            </div>

        </div>

    </section> -->



    <!-- ABOUT -->

    <section class="pb-28">

        <div class="max-w-6xl mx-auto px-6 lg:px-10 text-center">

            <span class="uppercase tracking-[6px] text-[#C9A36B] font-semibold">

                Our Story

            </span>

            <h2 class="mt-5 font-serif text-5xl">

                Baking Memories Since 1998

            </h2>

            <p class="mt-8 max-w-3xl mx-auto text-lg text-[#6B5B50] leading-relaxed">

                At FLOURish, every loaf, pastry and cake is crafted
                with dedication, tradition and the finest ingredients.
                We believe baking is more than food—it's about creating
                moments worth sharing.

            </p>

            <a
                href="/about"
                class="inline-block mt-10 bg-[#C9A36B] text-[#2F241D] px-8 py-4 rounded-full font-semibold hover:bg-[#B89056] transition-all duration-300"
            >

                Learn More About Us

            </a>

        </div>

    </section>



    <!-- TESTIMONIALS -->

    <section class="pb-28">
    
        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <h2 class="text-center font-serif text-5xl mb-14">

                What Our Customers Say

            </h2>

            <div class="grid md:grid-cols-3 gap-8">

                <div class="bg-white rounded-2xl p-8 shadow-sm">

                    <div class="text-[#C9A36B] text-xl">

                        ★★★★★

                    </div>

                    <p class="mt-5 text-[#6B5B50]">

                        Best croissants I've ever had.
                        Fresh, flaky and absolutely delicious.

                    </p>

                    <h4 class="mt-6 font-semibold">

                        Sarah Johnson

                    </h4>

                </div>


                <div class="bg-white rounded-2xl p-8 shadow-sm">

                    <div class="text-[#C9A36B] text-xl">

                        ★★★★★

                    </div>

                    <p class="mt-5 text-[#6B5B50]">

                        Their custom birthday cake exceeded all expectations.

                    </p>

                    <h4 class="mt-6 font-semibold">

                        Michael Carter

                    </h4>

                </div>


                <div class="bg-white rounded-2xl p-8 shadow-sm">

                    <div class="text-[#C9A36B] text-xl">

                        ★★★★★

                    </div>

                    <p class="mt-5 text-[#6B5B50]">

                        The sourdough is worth coming back for every week.

                    </p>

                    <h4 class="mt-6 font-semibold">

                        Emma Wilson

                    </h4>

                </div>

            </div>

        </div>

    </section>



    <!-- NEWSLETTER -->

    <section class="pb-28">

        <div class="max-w-5xl mx-auto px-6">

            <div class="bg-[#4A3428] rounded-3xl p-12 text-center">

                <h2 class="font-serif text-5xl text-white">

                    Stay Updated

                </h2>

                <p class="mt-5 text-white/80">

                    Get notified about seasonal specials,
                    fresh menu items and exclusive offers.

                </p>

                <form class="mt-8 flex flex-col md:flex-row gap-4 justify-center">

                    <input
                        type="email"
                        placeholder="Enter your email"
                        class="bg-white px-5 py-4 rounded-md outline-none md:w-96"
                    >

                    <button
                        type="submit"
                        class="bg-[#C9A36B] px-8 py-4 rounded-md font-semibold hover:bg-[#B89056] transition"
                    >

                        Subscribe

                    </button>

                </form>

            </div>

        </div>

    </section>



    <!-- FOOTER -->

    <footer class="bg-gradient-to-b from-[#3A2E25] to-[#241B15] text-[#F8F4EE]">

        <div class="max-w-7xl mx-auto px-6 lg:px-10 py-20">

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12">

                <!-- Brand -->

                <div>

                    <h3 class="font-serif text-4xl">

                        FLOUR<span class="italic text-[#C9A36B]">ish</span>

                    </h3>

                    <p class="mt-5 text-[#D6C8B8] leading-relaxed">

                        Bringing warmth, comfort, and freshly baked goodness to every table. Crafted daily with passion and the finest ingredients.

                    </p>

                    <div class="flex gap-4 mt-6 text-xl">

                        <a href="#" class="hover:text-[#C9A36B] transition">
                            <i class="fa-brands fa-instagram"></i>
                        </a>

                        <a href="#" class="hover:text-[#C9A36B] transition">
                            <i class="fa-brands fa-facebook-f"></i>
                        </a>

                        <a href="#" class="hover:text-[#C9A36B] transition">
                            <i class="fa-brands fa-pinterest-p"></i>
                        </a>

                        <a href="#" class="hover:text-[#C9A36B] transition">
                            <i class="fa-brands fa-x-twitter"></i>
                        </a>

                    </div>

                </div>





                <!-- Quick Links -->

                <div>

                    <h4 class="font-semibold text-lg mb-5">

                        Quick Links

                    </h4>

                    <ul class="space-y-3 text-[#D6C8B8]">

                        <li>
                            <a href="/" class="hover:text-[#C9A36B] transition">
                                Home
                            </a>
                        </li>

                        <li>
                            <a href="/menu" class="hover:text-[#C9A36B] transition">
                                Menu
                            </a>
                        </li>

                        <li>
                            <a href="/about" class="hover:text-[#C9A36B] transition">
                                About Us
                            </a>
                        </li>

                        <li>
                            <a href="/contact" class="hover:text-[#C9A36B] transition">
                                Contact
                            </a>
                        </li>

                    </ul>

                </div>





                <!-- Contact -->

                <div>

                    <h4 class="font-semibold text-lg mb-5">

                        Contact

                    </h4>

                    <ul class="space-y-4 text-[#D6C8B8]">

                        <li class="flex items-center gap-3">

                            <i class="fa-solid fa-envelope text-[#C9A36B]"></i>

                            hello@flourish.com

                        </li>

                        <li class="flex items-center gap-3">

                            <i class="fa-solid fa-phone text-[#C9A36B]"></i>

                            +91 98765 43210

                        </li>

                        <li class="flex items-center gap-3">

                            <i class="fa-solid fa-location-dot text-[#C9A36B]"></i>

                            123 Baker Street

                        </li>

                    </ul>

                </div>





                <!-- Opening Hours -->

                <div>

                    <h4 class="font-semibold text-lg mb-5">

                        Opening Hours

                    </h4>

                    <ul class="space-y-3 text-[#D6C8B8]">

                        <li class="flex justify-between">

                            <span>Mon - Fri</span>
                            <span>8AM - 8PM</span>

                        </li>

                        <li class="flex justify-between">

                            <span>Saturday</span>
                            <span>8AM - 9PM</span>

                        </li>

                        <li class="flex justify-between">

                            <span>Sunday</span>
                            <span>9AM - 6PM</span>

                        </li>

                    </ul>

                </div>

            </div>


            <!-- Bottom Bar -->

            <div class="mt-12 pt-8 border-t border-[#4A3A2F] flex flex-col md:flex-row items-center justify-between gap-4 text-[#D6C8B8]">

                <p>

                    © 2026 FLOURish Bakery. All rights reserved.

                </p>

                <div class="flex gap-6">

                    <a href="#" class="hover:text-[#C9A36B] transition">
