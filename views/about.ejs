<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>About Us | FLOURish</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    >

</head>

<body class="bg-[#F8F4EE] text-[#4A3428] min-h-screen flex flex-col">




    <!-- NAVBAR -->

    <nav class="bg-[#F8F4EE]/80 backdrop-blur-md border-b border-[#E8DCCB]">

        <div class="max-w-7xl mx-auto">

            <div class="h-20 flex items-center justify-between">

                <a href="/" class="flex items-center gap-3">

                    <i class="fa-solid fa-wheat-awn text-3xl text-[#C9A36B]"></i>

                    <h1 class="font-serif text-4xl">

                        FLOUR<span class="italic text-[#C9A36B]">ish</span>

                    </h1>

                </a>

                <div class="flex items-center gap-8">

                    <a href="/" class="hover:text-[#C9A36B] transition">
                        Home
                    </a>

                    <a href="/menu" class="hover:text-[#C9A36B] transition">
                        Menu
                    </a>

                    <a href="/cart" class="hover:text-[#C9A36B] transition">
                        Cart
                    </a>

                </div>

            </div>

        </div>

    </nav>





    <!-- HERO -->

    <section class="py-24">

        <div class="max-w-7xl mx-auto px-6 lg:px-10 text-center">

            <p class="uppercase tracking-[0.3em] text-[#C9A36B]">

                OUR STORY

            </p>

            <h1 class="font-serif text-6xl lg:text-7xl mt-6">

                Baking Happiness Every Day
            </h1>

            <p class="max-w-3xl mx-auto mt-8 text-lg text-[#6B5B50] leading-relaxed">

                FLOURish began with a simple belief: great baking brings people together.
                Every loaf, pastry, cookie, and cake is crafted with care using quality
                ingredients and traditional baking techniques.

            </p>

        </div>

    </section>





    <!-- STORY -->

    <section class="pb-24">

        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <div class="grid lg:grid-cols-2 gap-16 items-center">

                <div>

                    <div class="h-[500px] bg-[#E8DCCB] rounded-3xl flex items-center justify-center">

                        <i class="fa-solid fa-bread-slice text-8xl text-[#C9A36B]"></i>

                    </div>

                </div>

                <div>

                    <h2 class="font-serif text-5xl">

                        Crafted With Passion
                    </h2>

                    <p class="mt-6 text-[#6B5B50] leading-relaxed">

                        What started as a small family kitchen quickly grew into a bakery
                        loved by the community. Our bakers wake before sunrise every day
                        to ensure every product reaches customers fresh from the oven.

                    </p>

                    <p class="mt-6 text-[#6B5B50] leading-relaxed">

                        We combine traditional recipes with modern creativity to create
                        baked goods that feel both familiar and exciting.

                    </p>

                </div>

            </div>

        </div>

    </section>





    <!-- VALUES -->

    <section class="py-24 bg-white">

        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <div class="text-center">

                <h2 class="font-serif text-5xl">

                    What We Believe
                </h2>

            </div>

            <div class="grid md:grid-cols-3 gap-8 mt-16">

                <div class="bg-[#FAF7F2] rounded-3xl p-10">

                    <i class="fa-solid fa-seedling text-4xl text-[#C9A36B]"></i>

                    <h3 class="font-serif text-3xl mt-6">

                        Quality Ingredients
                    </h3>

                    <p class="mt-4 text-[#6B5B50]">

                        We use carefully selected ingredients to ensure exceptional taste and freshness.

                    </p>

                </div>

                <div class="bg-[#FAF7F2] rounded-3xl p-10">

                    <i class="fa-solid fa-heart text-4xl text-[#C9A36B]"></i>

                    <h3 class="font-serif text-3xl mt-6">

                        Made With Care
                    </h3>

                    <p class="mt-4 text-[#6B5B50]">

                        Every item is handcrafted with attention to detail and consistency.

                    </p>

                </div>

                <div class="bg-[#FAF7F2] rounded-3xl p-10">

                    <i class="fa-solid fa-users text-4xl text-[#C9A36B]"></i>

                    <h3 class="font-serif text-3xl mt-6">

                        Community First
                    </h3>

                    <p class="mt-4 text-[#6B5B50]">

                        We believe food has the power to connect families, friends, and communities.

                    </p>

                </div>

            </div>

        </div>

    </section>





    <!-- STATS -->

    <section class="py-24">

        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <div class="grid md:grid-cols-4 gap-8 text-center">

                <div>

                    <h3 class="font-serif text-5xl text-[#C9A36B]">

                        10+

                    </h3>

                    <p class="mt-3 text-[#6B5B50]">

                        Years Experience

                    </p>

                </div>

                <div>

                    <h3 class="font-serif text-5xl text-[#C9A36B]">

                        50K+

                    </h3>

                    <p class="mt-3 text-[#6B5B50]">

                        Happy Customers

                    </p>

                </div>

                <div>

                    <h3 class="font-serif text-5xl text-[#C9A36B]">

                        100+

                    </h3>

                    <p class="mt-3 text-[#6B5B50]">

                        Bakery Items

                    </p>

                </div>

                <div>

                    <h3 class="font-serif text-5xl text-[#C9A36B]">

                        Daily

                    </h3>

                    <p class="mt-3 text-[#6B5B50]">

                        Freshly Baked

                    </p>

                </div>

            </div>

        </div>

    </section>





    <!-- CTA -->

    <section class="pb-24">

        <div class="max-w-5xl mx-auto px-6">

            <div class="bg-[#C9A36B] rounded-3xl p-16 text-center">

                <h2 class="font-serif text-5xl">

                    Ready To Taste The Difference?

                </h2>

                <p class="mt-6 max-w-2xl mx-auto">

                    Explore our freshly baked collection and find your next favorite treat.

                </p>

                <a
                    href="/menu"
                    class="inline-block mt-8 bg-white px-8 py-4 rounded-full font-semibold hover:scale-105 transition"
                >

                    Explore Menu

                </a>

            </div>

        </div>

    </section>





    <!-- FOOTER -->

    <footer class="border-t border-[#E8DCCB]">

        <div class="max-w-7xl mx-auto py-8 text-center">

            <p class="text-[#6B5B50]">

                © 2026 FLOURish Bakery. All rights reserved.

            </p>

        </div>

    </footer>

</body>
</html>