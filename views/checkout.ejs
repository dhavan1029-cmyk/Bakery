<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Checkout | FLOURish</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    >

</head>

<body class="bg-[#F8F4EE] text-[#4A3428] min-h-screen flex flex-col">




    <!-- NAVBAR -->

    <nav class="bg-[#F8F4EE]/80 backdrop-blur-md border-b border-[#E8DCCB]">

        <div class="max-w-7xl mx-auto">

            <div class="h-20 flex items-center justify-between">

                <a href="/" class="flex items-center gap-3">

                    <i class="fa-solid fa-wheat-awn text-3xl text-[#C9A36B]"></i>

                    <h1 class="font-serif text-4xl">

                        FLOUR<span class="italic text-[#C9A36B]">ish</span>

                    </h1>

                </a>

                <a href="/cart" class="hover:text-[#C9A36B] transition">

                    Back To Cart

                </a>

            </div>

        </div>

    </nav>





    <!-- HEADER -->

    <section class="py-16">

        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <h1 class="font-serif text-6xl">

                Checkout

            </h1>

            <p class="mt-3 text-[#6B5B50]">

                Complete your order and we'll start baking.

            </p>

        </div>

    </section>





    <section class="pb-24 flex-1">

        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <div class="grid lg:grid-cols-3 gap-10">




                <!-- FORM -->

                <div class="lg:col-span-2">

                    <div class="bg-white rounded-3xl p-8 shadow-sm">

                        <% if(error){ %>

                            <div class="mb-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl">

                                <%= error %>

                            </div>

                        <% } %>

                        <form
                            action="/checkout"
                            method="POST"
                            class="space-y-8"
                        >




                            <!-- CONTACT -->

                            <div>

                                <h2 class="font-serif text-3xl mb-5">

                                    Contact Information

                                </h2>

                                <div class="grid md:grid-cols-2 gap-5">

                                    <input
                                        type="text"
                                        name="fullName"
                                        placeholder="Full Name"
                                        required
                                        class="border border-[#E8DCCB] rounded-xl px-4 py-3 outline-none focus:border-[#C9A36B]"
                                    >

                                    <input
                                        type="tel"
                                        name="phone"
                                        placeholder="Phone Number"
                                        required
                                        class="border border-[#E8DCCB] rounded-xl px-4 py-3 outline-none focus:border-[#C9A36B]"
                                    >

                                </div>

                            </div>





                            <!-- ADDRESS -->

                            <div>

                                <h2 class="font-serif text-3xl mb-5">

                                    Delivery Address

                                </h2>

                                <div class="space-y-5">

                                    <input
                                        type="text"
                                        name="address"
                                        placeholder="Street Address"
                                        required
                                        class="w-full border border-[#E8DCCB] rounded-xl px-4 py-3 outline-none focus:border-[#C9A36B]"
                                    >

                                    <div class="grid md:grid-cols-3 gap-5">

                                        <input
                                            type="text"
                                            name="city"
                                            placeholder="City"
                                            required
                                            class="border border-[#E8DCCB] rounded-xl px-4 py-3 outline-none focus:border-[#C9A36B]"
                                        >

                                        <input
                                            type="text"
                                            name="state"
                                            placeholder="State"
                                            required
                                            class="border border-[#E8DCCB] rounded-xl px-4 py-3 outline-none focus:border-[#C9A36B]"
                                        >

                                        <input
                                            type="text"
                                            name="pincode"
                                            placeholder="Pincode"
                                            required
                                            class="border border-[#E8DCCB] rounded-xl px-4 py-3 outline-none focus:border-[#C9A36B]"
                                        >

                                    </div>

                                </div>

                            </div>





                            <!-- PAYMENT -->

                            <div>

                                <h2 class="font-serif text-3xl mb-5">

                                    Payment Method

                                </h2>

                                <div class="space-y-4">

                                    <label class="flex items-center gap-3 border border-[#E8DCCB] rounded-xl p-4 cursor-pointer">

                                        <input
                                            type="radio"
                                            name="paymentMethod"
                                            value="cod"
                                            checked
                                        >

                                        <span>

                                            Cash On Delivery

                                        </span>

                                    </label>

                                    <label class="flex items-center gap-3 border border-[#E8DCCB] rounded-xl p-4 cursor-pointer">

                                        <input
                                            type="radio"
                                            name="paymentMethod"
                                            value="online"
                                        >

                                        <span>

                                            Online Payment

                                        </span>

                                    </label>

                                </div>

                            </div>





                            <button
                                type="submit"
                                class="w-full bg-[#C9A36B] py-4 rounded-xl font-semibold hover:bg-[#B89056] transition"
                            >

                                Place Order

                            </button>

                        </form>

                    </div>

                </div>






                <!-- ORDER SUMMARY -->

                <div>

                    <div class="bg-white rounded-3xl p-8 shadow-sm sticky top-10">

                        <h2 class="font-serif text-4xl">

                            Order Summary

                        </h2>

                        <div class="mt-8 space-y-5">

                            <% cartItems.forEach(item => { %>

                                <div class="flex justify-between">

                                    <div>

                                        <p>

                                            <%= item.name %>

                                        </p>

                                        <p class="text-sm text-[#6B5B50]">

                                            Qty: <%= item.quantity %>

                                        </p>

                                    </div>

                                    <span>

                                        ₹<%= item.price * item.quantity %>

                                    </span>

                                </div>

                            <% }) %>

                        </div>

                        <div class="border-t border-[#E8DCCB] mt-8 pt-6 space-y-4">

                            <div class="flex justify-between">

                                <span>Subtotal</span>

                                <span>₹<%= subtotal %></span>

                            </div>

                            <div class="flex justify-between">

                                <span>Delivery</span>

                                <span>₹<%= deliveryFee %></span>

                            </div>

                            <div class="flex justify-between font-bold text-xl">

                                <span>Total</span>

                                <span>₹<%= total %></span>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>





    <footer class="bg-gradient-to-b from-[#3A2E25] to-[#241B15] text-[#F8F4EE]">

        <div class="max-w-7xl mx-auto py-8 text-center">

            <p class="text-[#6B5B50]">

                © 2026 FLOURish Bakery. All rights reserved.

            </p>

        </div>

    </footer>

</body>
</html>