<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Our Menu | FLOURish</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

</head>

<body class="bg-[#F8F4EE] text-[#4A3428]">




    <!-- NAVBAR -->

    <nav class="sticky top-0 left-0 w-full z-50 bg-[#F8F4EE]/80 backdrop-blur-md border-b border-[#E8DCCB]">

        <div class="w-[90%] mx-auto ">

            <div class="h-20 flex items-center justify-between">

                <a href="/" class="flex items-center gap-3">

                    <i class="fa-solid fa-wheat-awn text-3xl text-[#C9A36B]"></i>

                    <h1 class="font-serif text-4xl">

                        FLOUR<span class="italic text-[#C9A36B]">ish</span>

                    </h1>

                </a>

                <div class="flex items-center gap-6">

                    <a href="/cart">
                        <i class="fa-solid fa-cart-shopping text-lg hover:text-[#C9A36B] transition"></i>
                    </a>

                    <a href="/login">
                        <i class="fa-regular fa-user text-lg hover:text-[#C9A36B] transition"></i>
                    </a>

                </div>

            </div>

        </div>

    </nav>




    <!-- HERO -->

    <section class="py-20">

        <div class="max-w-7xl mx-auto px-6 lg:px-10 text-center">

            <h1 class="font-serif text-6xl md:text-7xl">

                Our Menu

            </h1>

            <p class="mt-5 text-[#6B5B50] text-lg">

                Freshly baked breads, pastries, cakes and sweet treats.

            </p>

        </div>

    </section>




    <!-- SEARCH -->

    <section class="pb-8">

        <div class="relative max-w-3xl mx-auto px-6">

            <form id="productSearchBar">

                <div class="relative">

                    <i class="fa-solid fa-magnifying-glass absolute left-5 top-1/2 -translate-y-1/2 text-[#8B7765]"></i>

                    <input
                        type="text"
                        name="q"
                        placeholder="Search products..."
                        class="w-full bg-white rounded-full border border-[#E8DCCB] py-4 pl-14 pr-5 outline-none focus:border-[#C9A36B]"
                    >

                </div>

            </form>

            <div id="searchResults" class="hidden absolute max-h-[16.5rem] left-6 right-6 mt-2 bg-white border border-[#E8DCCB] rounded-2xl shadow-lg overflow-auto z-50">

                <div id="loadingAnimation" class="hidden">

                    <div class="bg-white rounded-2xl border border-[#E8DCCB] shadow-lg overflow-hidden">

                        <!-- Skeleton Result -->

                        <div class="animate-pulse flex items-center gap-4 p-4 border-b border-[#F3ECE3]">

                            <div class="w-14 h-14 rounded-lg bg-[#E8DCCB]"></div>

                            <div class="flex-1">

                                <div class="h-4 w-40 bg-[#E8DCCB] rounded"></div>

                                <div class="h-3 w-20 bg-[#E8DCCB] rounded mt-3"></div>

                            </div>

                        </div>

                        <!-- Skeleton Result -->

                        <div class="animate-pulse flex items-center gap-4 p-4 border-b border-[#F3ECE3]">
                        
                            <div class="w-14 h-14 rounded-lg bg-[#E8DCCB]"></div>
                        
                            <div class="flex-1">
                            
                                <div class="h-4 w-32 bg-[#E8DCCB] rounded"></div>
                            
                                <div class="h-3 w-24 bg-[#E8DCCB] rounded mt-3"></div>
                            
                            </div>
                        
                        </div>
                    
                        <!-- Skeleton Result -->
                    
                        <div class="animate-pulse flex items-center gap-4 p-4">
                        
                            <div class="w-14 h-14 rounded-lg bg-[#E8DCCB]"></div>
                        
                            <div class="flex-1">
                            
                                <div class="h-4 w-48 bg-[#E8DCCB] rounded"></div>
                            
                                <div class="h-3 w-16 bg-[#E8DCCB] rounded mt-3"></div>
                            
                            </div>
                        
                        </div>

                    </div>

                </div>

                <div id="noSearchResults" class="hidden py-12 px-6 text-center">

                    <div class="w-20 h-20 mx-auto rounded-full bg-[#F5EBDD] flex items-center justify-center">

                        <i class="fa-solid fa-magnifying-glass text-3xl text-[#C9A36B]"></i>

                    </div>

                    <h3 class="mt-6 font-serif text-2xl">

                        No Products Found

                    </h3>

                </div>
            
            </div>
        
        </div>

    </section>




    <!-- FILTERS -->

    <section class="pb-16">

        <div class="max-w-7xl mx-auto px-6 lg:px-10">

            <div class="flex flex-wrap justify-center gap-4">

                <button class="bg-[#C9A36B] px-6 py-3 rounded-full font-semibold" id="all">
                    All
                </button>

                <button class="bg-white border border-[#E8DCCB] px-6 py-3 rounded-full" id="breads">
                    Breads
                </button>

                <button class="bg-white border border-[#E8DCCB] px-6 py-3 rounded-full" id="pastries">
                    Pastries
                </button>

                <button class="bg-white border border-[#E8DCCB] px-6 py-3 rounded-full" id="cakes">
                    Cakes
                </button>

                <button class="bg-white border border-[#E8DCCB] px-6 py-3 rounded-full" id="cookies">
                    Cookies
                </button>

            </div>

        </div>

    </section>




    <!-- PRODUCTS -->

    <section class="pb-24">

        <div class="max-w-7xl mx-auto px-6 lg:px-10">
            <div class="hidden text-center py-20" id="noProducts">
            
                <i class="fa-solid fa-bread-slice text-7xl text-[#C9A36B]"></i>

                <h2 class="mt-6 text-3xl font-serif">
                    No Products Found
                </h2>

            </div>

            

            <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8" id="products">

                <% products.forEach(product => { %>

                    <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition" category=<%=product.category%>>

                        <!-- PRODUCT IMAGE -->

                        <div
                            class="h-64 flex items-center justify-center bg-[#E8DCCB]"
                            style="<%= product.image ? `background-image:url('${product.image}'); background-size:cover; background-position:center;` : '' %>"
                         >

                            <% if(!product.image){ %>

                                <% if(product.category === 'Breads'){ %>

                                    <i class="fa-solid fa-bread-slice text-7xl text-[#C9A36B]"></i>

                                <% } else if(product.category === 'Pastries'){ %>

                                    <i class="fa-solid fa-croissant text-7xl text-[#C9A36B]"></i>

                                <% } else if(product.category === 'Cakes'){ %>

                                    <i class="fa-solid fa-cake-candles text-7xl text-[#C9A36B]"></i>

                                <% } else { %>

                                    <i class="fa-solid fa-cookie-bite text-7xl text-[#C9A36B]"></i>

                                <% } %>

                            <% } %>

                        </div>

                        <!-- CONTENT -->

                        <div class="p-5">

                            <p class="uppercase tracking-wide text-xs text-[#C9A36B]">

                                <%= product.category %>

                            </p>

                            <h3 class="font-serif text-2xl mt-2 line-clamp-1">

                                <%= product.name %>

                            </h3>

                            <p class="mt-3 text-[#6B5B50] line-clamp-2">

                                <%= product.description %>

                            </p>

                            <div class="mt-5 flex items-center justify-between">

                                <span class="font-bold text-xl">

                                    ₹<%= product.price %>

                                </span>

                                <a
                                    href="/product/<%= product._id %>"
                                    class="bg-[#C9A36B] px-4 py-2 rounded-md font-medium hover:bg-[#B89056] transition"
                                >

                                    View

                                </a>

                            </div>

                        </div>

                    </div>

                <% }) %>

            </div>

        </div>

    </section>




    <!-- FOOTER -->

    <footer class="bg-gradient-to-b from-[#3A2E25] to-[#241B15] text-[#F8F4EE]">

        <div class="max-w-7xl mx-auto px-6 lg:px-10 py-12">

            <div class="flex flex-col md:flex-row justify-between items-center gap-6">

                <h3 class="font-serif text-3xl">

                    FLOUR<span class="italic text-[#C9A36B]">ish</span>

                </h3>

                <div class="flex gap-5 text-xl">

                    <i class="fa-brands fa-instagram"></i>

                    <i class="fa-brands fa-facebook"></i>

                    <i class="fa-brands fa-pinterest"></i>

                    <i class="fa-brands fa-x-twitter"></i>

                </div>

            </div>

            <div class="text-center mt-10 text-[#6B5B50]">

                © 2026 FLOURish Bakery. All rights reserved.

            </div>

        </div>

    </footer>

    <script>
        const products = JSON.parse('<%- JSON.stringify(products) %>');
    </script>
    <script src="/scripts/menu.js"></script>
</body>
</html>