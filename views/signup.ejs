<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Create Account | FLOURish</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    >

</head>

<body class="bg-[#F8F4EE] text-[#4A3428] min-h-screen flex flex-col">




    <!-- NAVBAR -->

    <nav class="bg-[#F8F4EE]/80 backdrop-blur-md border-b border-[#E8DCCB]">

        <div class="max-w-7xl mx-auto">

            <div class="h-20 flex items-center justify-between">

                <a href="/" class="flex items-center gap-3">

                    <i class="fa-solid fa-wheat-awn text-3xl text-[#C9A36B]"></i>

                    <h1 class="font-serif text-4xl">

                        FLOUR<span class="italic text-[#C9A36B]">ish</span>

                    </h1>

                </a>

                <a
                    href="/menu"
                    class="hover:text-[#C9A36B] transition"
                >

                    Browse Menu

                </a>

            </div>

        </div>

    </nav>





    <!-- SIGNUP CARD -->

    <main class="flex-1 flex items-center justify-center px-6 py-20">

        <div class="w-full max-w-md">

            <div class="bg-white rounded-3xl p-10 shadow-sm">

                <div class="text-center">

                    <h1 class="font-serif text-5xl">

                        Join FLOUR<span class="italic text-[#C9A36B]">ish</span>

                    </h1>

                    <p class="mt-3 text-[#6B5B50]">

                        Create your account and start ordering fresh bakery treats.

                    </p>

                </div>





                <% if(error){ %>

                    <div class="mt-8 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl">

                        <%= error %>

                    </div>

                <% } %>





                <form
                    action="/signup"
                    method="POST"
                    class="mt-8 space-y-5"
                >

                    <div>

                        <label
                            for="username"
                            class="block mb-2 font-medium"
                        >

                            Username

                        </label>

                        <input
                            id="username"
                            type="text"
                            name="username"
                            required
                            autocomplete="username"
                            placeholder="Enter your username"
                            class="w-full border border-[#E8DCCB] rounded-xl px-4 py-3 outline-none focus:border-[#C9A36B]"
                        >

                    </div>





                    <div>

                        <label
                            for="email"
                            class="block mb-2 font-medium"
                        >

                            Email

                        </label>

                        <input
                            id="email"
                            type="email"
                            name="email"
                            required
                            autocomplete="email"
                            placeholder="john@example.com"
                            class="w-full border border-[#E8DCCB] rounded-xl px-4 py-3 outline-none focus:border-[#C9A36B]"
                        >

                    </div>





                    <div>

                        <label
                            for="password"
                            class="block mb-2 font-medium"
                        >

                            Password

                        </label>

                        <input
                            id="password"
                            type="password"
                            name="password"
                            required
                            minlength="6"
                            autocomplete="new-password"
                            placeholder="Create a password"
                            class="w-full border border-[#E8DCCB] rounded-xl px-4 py-3 outline-none focus:border-[#C9A36B]"
                        >

                    </div>





                    <div>

                        <label
                            for="confirmPassword"
                            class="block mb-2 font-medium"
                        >

                            Confirm Password

                        </label>

                        <input
                            id="confirmPassword"
                            type="password"
                            name="confirmPassword"
                            required
                            minlength="6"
                            autocomplete="new-password"
                            placeholder="Confirm your password"
                            class="w-full border border-[#E8DCCB] rounded-xl px-4 py-3 outline-none focus:border-[#C9A36B]"
                        >

                    </div>





                    <button
                        type="submit"
                        class="w-full bg-[#C9A36B] py-4 rounded-xl font-semibold hover:bg-[#B89056] transition"
                    >

                        Create Account

                    </button>

                </form>





                <div class="mt-8 text-center">

                    <p class="text-[#6B5B50]">

                        Already have an account?

                        <a
                            href="/login"
                            class="text-[#C9A36B] font-semibold hover:underline"
                        >

                            Login

                        </a>

                    </p>

                </div>

            </div>

        </div>

    </main>





    <!-- FOOTER -->

    <footer class="bg-gradient-to-b from-[#3A2E25] to-[#241B15] text-[#F8F4EE]">

        <div class="max-w-7xl mx-auto py-8 text-center">

            <p class="text-[#6B5B50]">

                © 2026 FLOURish Bakery. All rights reserved.

            </p>

        </div>

    </footer>

</body>
</html>